<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Matrix Digital Rain & Terminal</title>
    <style>
        /* Reset margins and hide scrollbars */
        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            background-color: black;
            font-family: 'Courier New', Courier, monospace;
        }

        canvas {
            display: block;
            position: absolute;
            top: 0;
            left: 0;
            z-index: 1;
        }

        /* Terminal Window Container - Hidden by default */
        .terminal-container {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 600px;
            height: 400px;
            max-width: 90vw;
            max-height: 80vh;
            background-color: rgba(0, 5, 0, 0.85);
            border: 2px solid #0F0;
            box-shadow: 0 0 20px #0F0;
            border-radius: 5px;
            z-index: 10;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            opacity: 0;
            transition: opacity 0.5s ease;
            pointer-events: none; /* Block clicks until visible */
        }

        .terminal-container.visible {
            opacity: 1;
            pointer-events: auto;
        }

        /* Terminal Header Bar */
        .terminal-header {
            background-color: #021a02;
            border-bottom: 1px solid #0F0;
            padding: 8px 12px;
            color: #0F0;
            font-size: 14px;
            font-weight: bold;
            letter-spacing: 1px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .header-dots span {
            display: inline-block;
            width: 8px;
            height: 8px;
            background-color: #0F0;
            border-radius: 50%;
            margin-left: 5px;
            opacity: 0.7;
        }

        /* Terminal Output Area */
        .terminal-body {
            flex: 1;
            padding: 15px;
            overflow-y: auto;
            color: #0F0;
            font-size: 15px;
            line-height: 1.4;
            text-shadow: 0 0 2px rgba(0, 255, 0, 0.5);
        }

        /* Custom Scrollbar for the Terminal */
        .terminal-body::-webkit-scrollbar {
            width: 8px;
        }
        .terminal-body::-webkit-scrollbar-thumb {
            background: #023a02;
            border-radius: 4px;
        }
        .terminal-body::-webkit-scrollbar-thumb:hover {
            background: #0F0;
        }

        /* Input Prompt Row - Hidden until typing completes */
        .input-line {
            display: none;
            align-items: center;
            margin-top: 5px;
        }

        .prompt {
            color: #0F0;
            margin-right: 10px;
            font-weight: bold;
            white-space: nowrap;
        }

        .terminal-input {
            background: transparent;
            border: none;
            color: #FFF;
            font-family: 'Courier New', Courier, monospace;
            font-size: 15px;
            width: 100%;
            outline: none;
            text-shadow: 0 0 3px #FFF;
        }

        .system-msg {
            color: #88ff88;
            margin-bottom: 4px;
        }

        .error-msg {
            color: #ff3333;
            text-shadow: 0 0 2px #ff0000;
        }
    </style>
</head>
<body>

    <canvas id="matrixCanvas"></canvas>

    <div class="terminal-container" id="terminalWindow" onclick="focusInput()">
        <div class="terminal-header">
            <span>NEXUS_TERMINAL_v1.04</span>
            <div class="header-dots">
                <span></span><span></span><span></span>
            </div>
        </div>
        <div class="terminal-body" id="terminalBody">
